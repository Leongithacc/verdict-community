{
  "name": "verdict-community",
  "version": "0.1.0",
  "private": true,
  "description": "Backend community per Verdict — Cloudflare Worker + D1. Riceve esiti anonimi (EvidenceRecord), espone statistiche aggregate. Spec: WPEP/docs/V7_REMOTE_BACKEND_DESIGN.md",
  "scripts": {
